rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to the specific collections (tables) used by SafeDrop
    match /users/{document} { allow read, write: if true; }
    match /customers/{document} { allow read, write: if true; }
    match /jobs/{document} { allow read, write: if true; }
    match /inventory/{document} { allow read, write: if true; }
    match /leads/{document} { allow read, write: if true; }
    match /invoices/{document} { allow read, write: if true; }
    match /auditLogs/{document} { allow read, write: if true; }
  }
}
